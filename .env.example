# Source for the detector pipeline.
# Either a Twitch / YouTube URL (resolved through yt-dlp + ffmpeg)
# or a path to a local video file (demo mode — looped playback).
STREAM_URL=tmp/vod_chunk.mp4

# How often to sample frames, in seconds. 1.0 is a good default for demo VODs;
# on a live broadcast with bandwidth constraints, 2.0-3.0 works fine.
FRAME_INTERVAL=1.0
